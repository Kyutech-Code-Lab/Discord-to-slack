# 実行対象環境: test または production（未設定なら production 扱い）
# test のときは下の TEST_* を、production のときは無印の変数を読みます。
APP_ENV=test

# ===== test 用（テスト用 Discord / Slack / シート）=====
# Discord Application の公開鍵（署名検証に使用）
TEST_DISCORD_PUBLIC_KEY=
# Discord Application ID
TEST_DISCORD_APPLICATION_ID=
# Discord Bot トークン（コマンド登録・フォローアップ送信に使用）
TEST_DISCORD_BOT_TOKEN=
# Slack Bot トークン（xoxb-...）
TEST_SLACK_BOT_TOKEN=
# 参加者情報を取得する Google Sheets の CSV URL
TEST_GOOGLE_SHEETS_CSV_URL=
# /announce を実行できる Discord ユーザーID（カンマ区切り）
TEST_ALLOWED_DISCORD_USER_IDS=

# ===== production 用（本番 Discord / Slack / シート）=====
DISCORD_PUBLIC_KEY=
DISCORD_APPLICATION_ID=
DISCORD_BOT_TOKEN=
SLACK_BOT_TOKEN=
GOOGLE_SHEETS_CSV_URL=
ALLOWED_DISCORD_USER_IDS=
